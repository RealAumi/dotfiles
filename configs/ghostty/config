# === Theme ===
theme = Catppuccin Mocha

# === Font ===
font-family = "Maple Mono NF CN"
font-size = 13
font-thicken = false

# === Background ===
background-opacity = 0.92
background-blur-radius = 20

# === Window ===
window-padding-x = 8
window-padding-y = 4
window-padding-balance = true
window-save-state = always
resize-overlay = after-first

# === Cursor ===
cursor-style = bar
cursor-style-blink = false

# === Clipboard ===
clipboard-read = allow
clipboard-write = allow

# === Shell Integration ===
shell-integration = detect
shell-integration-features = cursor,sudo,title

# === Quick Terminal (global hotkey) ===
keybind = global:ctrl+backquote=toggle_quick_terminal
quick-terminal-position = top
quick-terminal-animation-duration = 0.15
quick-terminal-screen = mouse

# === Split Panes ===
keybind = cmd+d=new_split:right
keybind = cmd+shift+d=new_split:down
keybind = cmd+alt+left=goto_split:left
keybind = cmd+alt+right=goto_split:right
keybind = cmd+alt+up=goto_split:top
keybind = cmd+alt+down=goto_split:bottom
keybind = cmd+shift+equal=equalize_splits
keybind = cmd+shift+z=toggle_split_zoom

# === macOS ===
macos-titlebar-style = tabs
macos-option-as-alt = true

# === Cmd → Ctrl forwarding (for micro etc.) ===
keybind = cmd+s=text:\x13
keybind = cmd+backspace=text:\x15
