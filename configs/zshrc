eval "$(mise activate zsh)"

# Plugins
source $(brew --prefix)/share/zsh-autosuggestions/zsh-autosuggestions.zsh
source $(brew --prefix)/share/zsh-syntax-highlighting/zsh-syntax-highlighting.zsh

# Prompt
eval "$(starship init zsh)"

# Transient prompt: collapse previous prompts to ♡ after Enter
_transient_prompt_precmd() {
  PROMPT="$(starship prompt)"
}
_transient_prompt_accept() {
  PROMPT=$'\e[1;38;2;245;169;184m♡\e[0m '
  zle .reset-prompt
  echo
  zle .accept-line
}
precmd_functions+=(_transient_prompt_precmd)
zle -N accept-line _transient_prompt_accept

# zoxide (smart cd)
eval "$(zoxide init zsh)"

# fzf (fuzzy finder)
source <(fzf --zsh)

# Default editor
export EDITOR="code --wait"
export VISUAL="code --wait"

# Aliases
alias cat="bat"
alias ls="eza --icons --group-directories-first --hyperlink"
alias ll="eza --icons --group-directories-first --hyperlink -la"
alias lt="eza --icons --tree --level=2 --hyperlink"
alias lg="lazygit"
alias cc="claude --dangerously-skip-permissions"

# bun completions
[ -s "$HOME/.bun/_bun" ] && source "$HOME/.bun/_bun"

# pnpm
export PNPM_HOME="$HOME/Library/pnpm"
case ":$PATH:" in
  *":$PNPM_HOME:"*) ;;
  *) export PATH="$PNPM_HOME:$PATH" ;;
esac
